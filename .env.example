# Job Application Tracker — environment configuration (Week 7)
#
# Copy this file to .env (which is gitignored) and fill in your values:
#   cp .env.example .env
#   nano .env
#
# All variables below are REQUIRED at app startup. The app reads them via
# os.environ[...] (strict) and will crash on import if any are missing.
# Flask session signing key. Generate locally with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-32-byte-random-hex
# Database URL. Use Postgres for docker-compose, or sqlite for local hacking:
#   sqlite:///dev.db
DATABASE_URL=postgresql://app:app@db:5432/app
# GitHub OAuth app credentials (create at https://github.com/settings/developers).
# OAUTH_CLIENT_SECRET is highly sensitive — anyone with it can impersonate the app.
OAUTH_CLIENT_ID=your-github-client-id
OAUTH_CLIENT_SECRET=your-github-client-secret
# Optional cookie / session hardening overrides. Leave unset to use the
# secure-by-default values baked into app.py.
# SESSION_COOKIE_SECURE=true
# REMEMBER_COOKIE_SECURE=true
# PERMANENT_SESSION_LIFETIME_SECONDS=1209600
# REMEMBER_COOKIE_DURATION_SECONDS=1209600
